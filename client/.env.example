# Optional TMDB poster enrichment (client-side; must be NEXT_PUBLIC_ for browser)
NEXT_PUBLIC_TMDB_KEY=

# Server-side TMDB (if used elsewhere)
TMDB_API_KEY=

# Search API base URL (defaults to http://localhost:5000)
NEXT_PUBLIC_GODS_EYE_API_URL=http://localhost:5000
NEXT_PUBLIC_TBOOM_API_URL=http://localhost:5000

# Site branding
NEXT_PUBLIC_SITE_NAME=CHITHRA — CINEMA

# Legacy API base (used if TBOOM_API_URL unset)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
