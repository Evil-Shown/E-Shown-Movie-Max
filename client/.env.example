
# Backend API base URL
# Local: http://localhost:5000
# Production: leave unset (same-origin /api/v1 → Render) OR set Render URL
# NEXT_PUBLIC_API_BASE_URL=https://chithra-cinema-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000
NEXT_PUBLIC_GODS_EYE_API_URL=http://localhost:5000
NEXT_PUBLIC_TBOOM_API_URL=http://localhost:5000

# Public site URL (OAuth redirects). Required on Vercel if Supabase Site URL was localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production example:
# NEXT_PUBLIC_APP_URL=https://chithracinema.vercel.app

# Server-only (Vercel rewrite target for /api/v1/*). Optional if NEXT_PUBLIC is set.
# BACKEND_API_URL=https://chithra-cinema-api.onrender.com

# ── Supabase Auth (required for Google login on Vercel) ─────────────
# Project Settings → API → Project URL + anon/publishable key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: https://chithracinema.vercel.app
#   Redirect URLs: https://chithracinema.vercel.app/auth/callback
#                  http://localhost:3000/auth/callback

# Site branding
NEXT_PUBLIC_SITE_NAME=CHITHRA — CINEMA

# Route stream iframes through HTML-rewriting embed proxy (ad script strip + popup guard).
# Leave false for most providers (VidFast etc.) — proxy changes document origin and can
# leave the player stuck on "Fetching…". Enable only with a Worker/API you control and tested providers.
NEXT_PUBLIC_USE_EMBED_PROXY=false
# NEXT_PUBLIC_EMBED_PROXY_WORKER_URL=https://chithra-embed-proxy.your-subdomain.workers.dev
# NEXT_PUBLIC_EMBED_PROXY_API_URL=http://localhost:5000

# Desktop startup — 3D Spline carousel override
# NEXT_PUBLIC_SPLINE_STARTUP_SCENE=https://my.spline.design/your-scene/
# Or Export → Code → React: https://prod.spline.design/xxxxxxxx/scene.splinecode

# ── Live TV upstream (server-side only) ─────────────────────────────
# Session / Cloudflare cookies for Dialog TV or PEOTV (cf_clearance, etc.)
# STREAM_UPSTREAM_COOKIES=cf_clearance=...; session=...
# Sri Lankan IP when providers geo-gate (use with VPN/proxy in same region)
# STREAM_UPSTREAM_X_FORWARDED_FOR=203.115.x.x
# Extra headers as JSON — merged into every upstream stream request
# STREAM_UPSTREAM_EXTRA_HEADERS={"Authorization":"Bearer ..."}
# Route fetches through VPN/proxy (Node 20+ native fetch)
# HTTP_PROXY=http://127.0.0.1:8080
# HTTPS_PROXY=http://127.0.0.1:8080
# Enable headless Puppeteer scraping (requires: npm install puppeteer)
# STREAM_SCRAPER_BROWSER=1
# Random UA + decoy referer rotation on scrape retries
# STREAM_HEADER_ROTATION=1

# ── Upstash Redis (shared server-side state) ───────────────────────
# Required in production for proxy sessions, API caches, and rate limits.
# Create a free database at https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# Worldwide subtitles via Wyzie (get your free key at https://store.wyzie.io/redeem)
#WYZIE_API_KEY=wyzie_api_key_here
