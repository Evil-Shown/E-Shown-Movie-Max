{
  "name": "chithra-cinema",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/ensure-dev-cache.mjs",
    "dev": "next dev",
    "dev:clean": "node scripts/clean-next.mjs && next dev",
    "clean": "node scripts/clean-next.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "scrape:tv": "node scripts/scrape-dialog-peotv.mjs",
    "probe:tv": "node scripts/probe-providers.mjs",
    "test:e2e": "playwright test",
    "test:e2e:memory": "set NODE_OPTIONS=--max-old-space-size=4096&& npx playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@chithra/core": "file:../packages/core",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "^10.66.0",
    "@splinetool/react-spline": "^4.1.0",
    "@splinetool/runtime": "^1.12.97",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.0",
    "@upstash/redis": "^1.38.0",
    "framer-motion": "^12.40.0",
    "hls.js": "^1.6.16",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "~1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "puppeteer": "^24.43.1"
  }
}
