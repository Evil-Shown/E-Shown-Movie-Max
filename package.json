{
  "name": "chithra-cinema-monorepo",
  "private": true,
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "client",
    "mobile",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint && eslint server packages",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-desktop.ps1",
    "package:current": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-desktop.ps1 -NoIncrement",
    "package:version": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-desktop.ps1 -Version",
    "package:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-for-friend.ps1",
    "package:publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-desktop-release.ps1",
    "package:publish:current": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-desktop-release.ps1 -NoIncrement",
    "package:publish:version": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-desktop-release.ps1 -Version",
    "release:desktop": "gh workflow run release-desktop.yml",
    "release:mobile": "node scripts/release-mobile.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.7.4",
    "prompts": "^2.4.2",
    "turbo": "^2.5.4",
    "typescript-eslint": "^8.52.0"
  }
}
