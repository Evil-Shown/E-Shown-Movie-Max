# VirusTotal hash checks for God's Eye security button
VIRUSTOTAL_API_KEY=0e617b86d3e9bbe514aadb35867bc46ab141bd6621cf92d3388c4d5ffcc81cc5

PORT=5000

# TMDB API key — used by the mobile API proxy routes.
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── Upstash Redis (shared server-side state) ───────────────────────
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# Embed proxy — optional rotating HTTP proxies (comma-separated)
# EMBED_PROXY_LIST=http://user:pass@proxy1.example.com:8080,http://proxy2.example.com:8080

# Embed proxy cache TTL in ms (default 1 hour)
# EMBED_CACHE_TTL_MS=3600000