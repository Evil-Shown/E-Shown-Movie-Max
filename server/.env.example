# VirusTotal hash checks for God's Eye security button
#VIRUSTOTAL_API_KEY=0e617b86d3e9bbe514aadb35867bc46ab141bd6621cf92d3388c4d5ffcc81cc5

#PORT=5000

# TMDB API key — used by the mobile API proxy routes.
# Get one at https://www.themoviedb.org/settings/api
#TMDB_API_KEY=your_tmdb_api_key_here

# ── Supabase ───────────────────────────────────────────────────────
# Get these from your Supabase project settings: https://supabase.com/dashboard
#SUPABASE_URL=https://lviiplpwcyufuiisoyib.supabase.co
#SUPABASE_ANON_KEY=your_anon_key_here
#SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── PostgreSQL (via Supabase) ──────────────────────────────────────
# Get the connection string from your Supabase project settings → Database → Connection string
#DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public

VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
PORT=5000
TMDB_API_KEY=your_tmdb_api_key_here

# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://lviiplpwcyufuiisoyib.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── PostgreSQL (Neon) ─────────────────────────────────────────────
DATABASE_URL=your_neon_database_url_here

# ── PostgreSQL (via Supabase — kept as backup) ─────────────────────
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Upstash Redis (shared server-side state) ───────────────────────
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here

# Embed proxy — optional rotating HTTP proxies (comma-separated)
# EMBED_PROXY_LIST=http://user:pass@proxy1.example.com:8080,http://proxy2.example.com:8080

# Embed proxy cache TTL in ms (default 1 hour)
# EMBED_CACHE_TTL_MS=3600000

# ── Logging ────────────────────────────────────────────────────────
# LOG_LEVEL=info