# ── Server ───────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or local)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ── Supabase Auth ────────────────────────────────────────────────────
# Get from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# ── External APIs ────────────────────────────────────────────────────
# TMDB API key (required) - Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Per-platform TMDB keys (optional — override TMDB_API_KEY per platform)
# TMDB_API_KEY_WEB=
# TMDB_API_KEY_DESKTOP=
# TMDB_API_KEY_MOBILE=

# VirusTotal API key (optional) - Get from https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Per-platform VirusTotal keys (optional)
# VIRUSTOTAL_API_KEY_WEB=
# VIRUSTOTAL_API_KEY_DESKTOP=
# VIRUSTOTAL_API_KEY_MOBILE=

# OMDB API key (optional) - Get from https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=your_omdb_api_key_here

# Per-platform OMDB keys (optional)
# OMDB_API_KEY_WEB=
# OMDB_API_KEY_DESKTOP=
# OMDB_API_KEY_MOBILE=

# Wyzie API key (optional) - Get from https://store.wyzie.io/redeem
WYZIE_API_KEY=your_wyzie_api_key_here

# Per-platform Wyzie keys (optional)
# WYZIE_API_KEY_WEB=
# WYZIE_API_KEY_DESKTOP=
# WYZIE_API_KEY_MOBILE=

# ── Application URLs ─────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
CORS_ORIGIN=

# ── PayHere Payment Gateway ──────────────────────────────────────────
# Get from https://support.payhere.lk (Merchant account)
PAYHERE_MERCHANT_ID=your_merchant_id_here
PAYHERE_SECRET=your_merchant_secret_here
# Sandbox: https://sandbox.payhere.lk
# Production: https://payhere.lk
PAYHERE_API_URL=https://sandbox.payhere.lk

# ── Telemetry ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TELEMETRY_KEY=generate_random_hex_string_here

# ── Redis / Upstash (optional — in-memory fallback used if missing) ──
# Create free database at https://console.upstash.com/
#UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
#UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── Embed Proxy (optional) ──────────────────────────────────────────
# EMBED_PROXY_LIST=http://proxy1:8080,http://proxy2:8080
EMBED_PROXY_LIST=
EMBED_CACHE_TTL_MS=3600000
EMBED_REQUEST_TIMEOUT_MS=15000

# ── Logging ──────────────────────────────────────────────────────────
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
