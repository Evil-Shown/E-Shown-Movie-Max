# ── Server ───────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (with password)
DATABASE_URL=postgresql://postgres:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── Supabase Auth ────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── External APIs ────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here

# Per-platform TMDB keys (optional — uncomment to override TMDB_API_KEY per platform)
# TMDB_API_KEY_WEB=
# TMDB_API_KEY_DESKTOP=
# TMDB_API_KEY_MOBILE=

# VIRUSTOTAL_API_KEY=

# Per-platform VirusTotal keys (optional — uncomment to override VIRUSTOTAL_API_KEY per platform)
# VIRUSTOTAL_API_KEY_WEB=
# VIRUSTOTAL_API_KEY_DESKTOP=
# VIRUSTOTAL_API_KEY_MOBILE=

# OMDB_API_KEY=

# Per-platform OMDB keys (optional — uncomment to override OMDB_API_KEY per platform)
# OMDB_API_KEY_WEB=
# OMDB_API_KEY_DESKTOP=
# OMDB_API_KEY_MOBILE=

# WYZIE_API_KEY=

# Per-platform Wyzie keys (optional — uncomment to override WYZIE_API_KEY per platform)
# WYZIE_API_KEY_WEB=
# WYZIE_API_KEY_DESKTOP=
# WYZIE_API_KEY_MOBILE=

# ── Application URLs ─────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:5000
# CORS_ORIGIN=

# ── PayHere Payment Gateway ──────────────────────────────────────────
# Get from: https://support.payhere.lk (Merchant account)
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_SECRET=your_merchant_secret
# Sandbox: https://sandbox.payhere.lk
# Production: https://payhere.lk
PAYHERE_API_URL=https://sandbox.payhere.lk

# ── Telemetry ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TELEMETRY_KEY=replace_with_random_hex_string

# ── Redis / Upstash (optional — in-memory fallback used if missing) ──
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# ── Embed Proxy (optional) ──────────────────────────────────────────
# EMBED_PROXY_LIST=http://proxy1:8080,http://proxy2:8080
# EMBED_CACHE_TTL_MS=3600000
# EMBED_REQUEST_TIMEOUT_MS=15000

# ── Logging ──────────────────────────────────────────────────────────
# LOG_LEVEL=info
