# ── Supabase Auth ──────────────────────────────────────────────────
# Dashboard → Project Settings → API (same project as DATABASE_URL)
# Use either new keys (sb_publishable_ / sb_secret_) or legacy JWT keys (anon / service_role).
# If you see "Unregistered API key", regenerate keys in the dashboard and update this file.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_... or eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... or eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Database ───────────────────────────────────────────────────────
# Supabase: Settings → Database → Connection string (with password)
DATABASE_URL=postgresql://postgres:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# ── External APIs ──────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key_here
# Optional (platform overrides fall back to the base key):
# TMDB_API_KEY_WEB=
# TMDB_API_KEY_DESKTOP=
# TMDB_API_KEY_MOBILE=
# VIRUSTOTAL_API_KEY=
# VIRUSTOTAL_API_KEY_WEB=
# VIRUSTOTAL_API_KEY_DESKTOP=
# VIRUSTOTAL_API_KEY_MOBILE=
# OMDB_API_KEY=
# OMDB_API_KEY_WEB=
# OMDB_API_KEY_DESKTOP=
# OMDB_API_KEY_MOBILE=
# WYZIE_API_KEY=
# WYZIE_API_KEY_WEB=
# WYZIE_API_KEY_DESKTOP=
# WYZIE_API_KEY_MOBILE=

# ── PayHere Payment Gateway ────────────────────────────────────────
# Get from: https://support.payhere.lk (Merchant account)
PAYHERE_MERCHANT_ID=your_merchant_id
PAYHERE_SECRET=your_merchant_secret
# Sandbox: https://sandbox.payhere.lk
# Production: https://payhere.lk
PAYHERE_API_URL=https://sandbox.payhere.lk

# ── Application URLs ──────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# ── Telemetry Admin Key ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TELEMETRY_KEY=replace_with_random_hex_string

# ── Redis / Upstash (optional — in-memory fallback used if missing) ──
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# ── Embed Proxy (optional) ─────────────────────────────────────────
# EMBED_PROXY_LIST=http://proxy1:8080,http://proxy2:8080

# ── Port ────────────────────────────────────────────────────────────
PORT=5000

# ── Desktop Proxy Mode (optional) ──────────────────────────────────
# When set, sensitive routes (TMDB, auth, DB, etc.) are proxied to
# this URL instead of being handled locally. Used by the desktop build
# to keep API keys on the server, not in the installer.
# RENDER_API_URL=https://chithra-cinema-api.onrender.com
